{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "correctness.schema.json",
  "title": "Correctness Test Results",
  "description": "Results from a correctness test run against a hashcat variant.",
  "type": "object",
  "required": [
    "attack_mode",
    "total_tested",
    "passed",
    "failed"
  ],
  "properties": {
    "attack_mode": {
      "type": "integer",
      "description": "Hashcat attack mode used",
      "enum": [0, 1, 3]
    },
    "total_tested": {
      "type": "integer",
      "description": "Total number of test cases run",
      "minimum": 0
    },
    "passed": {
      "type": "integer",
      "description": "Number of passing test cases",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "description": "Number of failing test cases",
      "minimum": 0
    },
    "all_passed": {
      "type": "boolean",
      "description": "Whether all tests passed"
    },
    "details": {
      "type": "array",
      "description": "Per-test-case details",
      "items": {
        "type": "object"
      }
    }
  }
}
